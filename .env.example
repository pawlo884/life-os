# Supabase PostgreSQL
# Dashboard → Project Settings → Database → Connection string → URI
# You can paste postgresql:// — the backend converts it to postgresql+asyncpg://
#
# Session pooler (recommended for apps):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# Transaction pooler (port 6543, better for high connection counts):
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Direct connection (IPv6, local dev):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Discord Bot
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Google Calendar (Phase 3)
GOOGLE_CALENDAR_CREDENTIALS_PATH=

# Strava (Phase 3)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
