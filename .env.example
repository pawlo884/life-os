# Local Docker (default) — uses bundled Postgres container
DATABASE_URL=postgresql+asyncpg://lifeos:lifeos@db:5432/lifeos

# API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Discord Bot (optional — docker compose --profile discord up)
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Google Calendar (Phase 3)
GOOGLE_CALENDAR_CREDENTIALS_PATH=

# Strava (Phase 3)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=

# OpenRouter — AI broker for book lookup (title / link / cover photo)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=Life OS
OPENROUTER_APP_URL=http://localhost:5173

# Direct OpenAI (optional fallback if OpenRouter is not set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Supabase — replace DATABASE_URL when migrating to cloud
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
